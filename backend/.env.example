# ── Environnement ───────────────────────────────────────
APP_ENV=development            # development | testing | production

# ── Secrets (obligatoires en production) ────────────────
SECRET_KEY=change-me-in-prod-use-a-long-random-string
JWT_SECRET_KEY=                # vide = réutilise SECRET_KEY

# ── Base de données ─────────────────────────────────────
# Vide en dev => repli SQLite (backend/marveen_dev.db).
# Prod: postgresql://user:password@host:5432/marveen
DATABASE_URL=

# ── JWT / cookies ───────────────────────────────────────
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=30
JWT_COOKIE_SECURE=false        # true en prod (HTTPS)
JWT_COOKIE_SAMESITE=Lax

# ── CORS (origines du front, séparées par des virgules) ─
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Médias / uploads ────────────────────────────────────
MAX_CONTENT_MB=50

# ── i18n ────────────────────────────────────────────────
DEFAULT_LOCALE=fr
SUPPORTED_LOCALES=fr,en

# ── Super-admin (créé par `flask seed`) ─────────────────
ADMIN_EMAIL=admin@marveen.cms
ADMIN_PASSWORD=ChangeMe123!

# ── Flask CLI ───────────────────────────────────────────
FLASK_APP=wsgi.py

# ── AI (Anthropic Claude) ──────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-5
# AI_FAKE=1   # demo/dev mode: canned AI responses, no API calls

# Public self-registration (admin CMS: keep off; create users via the admin)
# ALLOW_PUBLIC_REGISTRATION=0

# ── Paiement (Stripe) ──────────────────────────────────
# Stripe Checkout gère automatiquement carte, Apple Pay, Google Pay et méthodes locales.
# STRIPE_SECRET_KEY=sk_live_ou_sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...          # secret du endpoint /api/stripe/webhook
# STRIPE_CURRENCY=eur
# PUBLIC_SITE_URL=http://localhost:3000    # pour les redirections succès/annulation
# STRIPE_FAKE=1   # mode démo : simule le paiement (aucune clé requise)
